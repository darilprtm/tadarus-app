{
  "expo": {
    "name": "Tadarus.id",
    "slug": "tadarus-id",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "darilapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f766e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daril.tadarusid",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.764554736649-21pjnaa1ut87lelfjpj7suevn3ccjea8"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.764554736649-21pjnaa1ut87lelfjpj7suevn3ccjea8"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.764554736649-21pjnaa1ut87lelfjpj7suevn3ccjea8"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f766e",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.daril.tadarusid"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6fb07c09-dc29-47da-a230-ff269da8fa01"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6fb07c09-dc29-47da-a230-ff269da8fa01"
    }
  }
}